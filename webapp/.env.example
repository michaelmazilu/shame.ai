# Supabase multiplayer (Edge Functions). Copy to webapp/.env.local — never commit .env.local
# These are read only on the server (Next API routes); they are not bundled into the client.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=

# Optional: legacy JWT anon key works too
# SUPABASE_ANON_KEY=
