# =============================================================================
# Instagram API tests (test/) — copy this file to `.env` and fill in.
# See CLAUDE.md — credentials are gitignored.
# =============================================================================

# Account 1
ACCOUNT1_USER_ID=
ACCOUNT1_COOKIES=
ACCOUNT1_CSRFTOKEN=

# Account 2
ACCOUNT2_USER_ID=
ACCOUNT2_COOKIES=
ACCOUNT2_CSRFTOKEN=

# Session headers (from DevTools > Network > any IG request > Request Headers)
X_IG_WWW_CLAIM=
X_INSTAGRAM_AJAX=

# GraphQL tokens (from intercepted requests)
FB_DTSG=
LSD=

# User-Agent (copy exact value from DevTools > Network > any IG request > Request Headers)
USER_AGENT=

# Azure OpenAI (for AI-generated confessions and FLUX image generation)
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_OPENAI_API_KEY=

# instagrapi login (for test/ig_story.py)
IG_USERNAME=
IG_PASSWORD=

# =============================================================================
# Supabase multiplayer — copy these lines to repo root `.env.local` (gitignored)
# and/or `webapp/.env.local` as `NEXT_PUBLIC_*`. Dashboard → Settings → API.
# =============================================================================

# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE
# Optional: KEY=...  (alias for scripts/shame-mp)
