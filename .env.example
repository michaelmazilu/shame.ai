# Instagram session credentials
# Copy this to .env and fill in your values from DevTools (Application > Cookies)

# Account 1
ACCOUNT1_USER_ID=
ACCOUNT1_COOKIES=
ACCOUNT1_CSRFTOKEN=

# Account 2
ACCOUNT2_USER_ID=
ACCOUNT2_COOKIES=
ACCOUNT2_CSRFTOKEN=

# Session headers (from DevTools > Network > any IG request > Request Headers)
X_IG_WWW_CLAIM=
X_INSTAGRAM_AJAX=

# GraphQL tokens (from intercepted requests)
FB_DTSG=
LSD=

# User-Agent (copy exact value from DevTools > Network > any IG request > Request Headers)
USER_AGENT=

# Azure OpenAI (for AI-generated confessions and FLUX image generation)
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_OPENAI_API_KEY=

# instagrapi login (for test/ig_story.py)
IG_USERNAME=
IG_PASSWORD=
